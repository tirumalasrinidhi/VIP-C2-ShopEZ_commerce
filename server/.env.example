# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shopez?retryWrites=true&w=majority

# JWT secret key (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Port (Render sets this automatically)
PORT=5000

# Frontend URL for CORS (your Vercel deployment URL)
CORS_ORIGIN=https://your-app-name.vercel.app
